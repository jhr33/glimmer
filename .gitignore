# ============================================================
# glimmer 项目根 .gitignore
# ============================================================

# 环境变量（含敏感信息，禁止提交）
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.iml
*.iws
*.ipr
.DS_Store
Thumbs.db

# 操作系统
*.swp
*.swo
*~

# 日志
*.log
logs/

# ===== 后端 =====
backend/target/
backend/.mvn/
backend/mvnw
backend/mvnw.cmd
*.class

# ===== 前端 =====
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ===== Docker 数据卷（本地开发时）=====
mysql_data/
uploads_data/
data/
